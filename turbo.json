{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": [
    ".env.local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        ".expo/**"
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "cache": true
    },
    "type-check": {
      "outputs": [],
      "cache": true
    }
  }
}
