# .env.example - Copie para .env.local e preencha com seus valores

# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Acesse: https://console.firebase.google.com
# Criar projeto → Configurações do projeto → Suas apps

REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=seu-projeto-id
REACT_APP_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123def456

# ========================================
# STORE CONFIGURATION
# ========================================
NEXT_PUBLIC_WHATSAPP=5511934491268
NEXT_PUBLIC_STORE_ADDRESS=Rua Dr Virgílio de Carvalho Pinto, 96 - Pinheiros, São Paulo
NEXT_PUBLIC_STORE_EMAIL=contato@donutsdamari.com
NEXT_PUBLIC_STORE_INSTAGRAM=donutsdamari

# ========================================
# PAYMENT GATEWAY (PagSeguro)
# ========================================
# Acesse: https://pagseguro.uol.com.br
NEXT_PUBLIC_PAGSEGURO_TOKEN=seu_token_publico
PAGSEGURO_SECRET_KEY=seu_token_secreto

# ========================================
# VERCEL & DEPLOYMENT
# ========================================
VERCEL_ENV=production
VERCEL_URL=https://donutsdamari.vercel.app

# ========================================
# EXPO & MOBILE
# ========================================
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com

# ========================================
# NOTIFICATIONS (Firebase Cloud Messaging)
# ========================================
# NEXT_PUBLIC_FCM_PUBLIC_KEY=BCy...

# ========================================
# ANALYTICS
# ========================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
